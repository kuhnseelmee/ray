# Environment variables
# Add any environment variables here for local development

# AI Assistant Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
AI_PROVIDER=openai
AI_TIMEOUT_MS=20000
NEXT_PUBLIC_ENABLE_AI=true

# PostgreSQL
DATABASE_URL=postgresql://ray:ray_password@localhost:6432/ray_portfolio
POSTGRES_USER=ray
POSTGRES_PASSWORD=ray_password
POSTGRES_DB=ray_portfolio
ADMIN_PASSWORD=change-me-for-local-admin-access
ADMIN_SESSION_SECRET=change-me-for-local-session-signing
# Optional admin role for enterprise platform controls: owner | admin | operator | viewer
ADMIN_ROLE=owner

# Optional: Local model (Ollama) - uncomment to use
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11535
# OLLAMA_MODEL=llama3.1
